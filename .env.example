# Existing application settings
# On Replit, DATABASE_URL is already provided by the environment — don't set
# it here. Running locally on your own computer, you can leave DATABASE_URL
# empty: the app then stores its data in a local file-based database
# (lib/db/.pglite-data) automatically — no separate Postgres/Docker install
# needed. Only set DATABASE_URL if you want to point at a real Postgres
# server instead.
DATABASE_URL=
SESSION_SECRET=change-me
PORT=3000

# Stealth-Requests integration for Instagram direct login.
# Set to false to disable the Python bridge and use native fetch only.
USE_STEALTH_REQUESTS=true

# Python interpreter for the Stealth-Requests bridge (optional).
# STEALTH_REQUESTS_PYTHON=python3

# Nothing else is needed here. The panel login (username & password) is
# entered on the app's own login screen and checked against the `users`
# table — it isn't an env var. The "Hedef URL" / headers / cookies used by
# the Settings page's "Test Et" button are also entered in the app UI and
# stored in the database (request_config table), not in this file.
