# Existing application settings
DATABASE_URL=
SESSION_SECRET=change-me
PORT=3000

# Instagram client. Prefer a serialized cookie jar or session cookie over a password.
INSTAGRAM_USERNAME=
INSTAGRAM_PASSWORD=
INSTAGRAM_SESSION_COOKIE=

# Optional script settings used by: pnpm --filter @workspace/scripts instagram:auto-like
TARGET_USERNAME=
CRON_SCHEDULE=0 */6 * * *
