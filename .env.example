# Existing application settings
# On Replit this is already provided by the environment — don't set it here.
# Running locally on your own computer instead (see README.md "Local setup"):
#   1. docker compose up -d
#   2. DATABASE_URL=postgresql://takipci:takipci@localhost:5432/takipci_paneli
DATABASE_URL=
SESSION_SECRET=change-me
PORT=3000

# Instagram client. Prefer a serialized cookie jar or session cookie over a password.
INSTAGRAM_USERNAME=
INSTAGRAM_PASSWORD=
INSTAGRAM_SESSION_COOKIE=

# Optional script settings used by: pnpm --filter @workspace/scripts instagram:auto-like
TARGET_USERNAME=
CRON_SCHEDULE=0 */6 * * *
