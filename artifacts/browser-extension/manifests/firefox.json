{
  "manifest_version": 3,
  "name": "Takipçi Paneli",
  "version": "1.0.0",
  "description": "Instagram oturumunu Takipçi Paneli'ne otomatik gönderir.",
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    },
    "default_title": "Takipçi Paneli"
  },
  "background": {
    "scripts": ["background.js"],
    "type": "module"
  },
  "permissions": ["cookies", "storage"],
  "host_permissions": ["*://*.instagram.com/*", "<all_urls>"],
  "browser_specific_settings": {
    "gecko": {
      "id": "takipci-paneli@extension",
      "strict_min_version": "109.0"
    }
  }
}
